# Server
PORT=5271
NODE_ENV=development
LOG_LEVEL=info
# Set to 'false' to disable, or a number (e.g. 1) to trust a specific number of proxy hops
TRUST_PROXY=true

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uem_migration
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Auth (for the migration tool's own auth)
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=8h

# UEM API Settings
UEM_API_TIMEOUT=30000
UEM_API_RATE_LIMIT_DELAY=200
UEM_API_MAX_RETRIES=3

# Migration Settings
MIGRATION_BATCH_SIZE=50
MIGRATION_MAX_CONCURRENT=5
SNAPSHOT_RETENTION_DAYS=30
